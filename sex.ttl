@prefix sex: <https://w3id.org/mesyto/vocab/sex/> .
@prefix mesyto: <https://w3id.org/mesyto/ontology#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

mesyto:sexConcept a rdfs:Class ;
    rdfs:label "sex concept"@en .

sex: a skos:ConceptScheme ;
    dcterms:title "Sex vocabulary"@en ;
    dcterms:creator "MeSyTo" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    skos:hasTopConcept sex:Female ,
                       sex:Male ,
                       sex:Hermaphrodite ,
                       sex:Unknown ,
                       sex:NotApplicable .

sex:Female a mesyto:sexConcept, skos:Concept ;
    rdfs:label "female"@en ;
    skos:prefLabel "female"@en ;
    skos:inScheme sex: ;
    skos:topConceptOf sex: .

sex:Male a mesyto:sexConcept, skos:Concept ;
    rdfs:label "male"@en ;
    skos:prefLabel "male"@en ;
    skos:inScheme sex: ;
    skos:topConceptOf sex: .

sex:Hermaphrodite a mesyto:sexConcept, skos:Concept ;
    rdfs:label "hermaphrodite"@en ;
    skos:prefLabel "hermaphrodite"@en ;
    skos:inScheme sex: ;
    skos:topConceptOf sex: .

sex:Unknown a mesyto:sexConcept, skos:Concept ;
    rdfs:label "unknown"@en ;
    skos:prefLabel "unknown"@en ;
    skos:inScheme sex: ;
    skos:topConceptOf sex: .

sex:NotApplicable a mesyto:sexConcept, skos:Concept ;
    rdfs:label "not applicable"@en ;
    skos:prefLabel "not applicable"@en ;
    skos:inScheme sex: ;
    skos:topConceptOf sex: .
