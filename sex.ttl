@prefix sex: <https://w3id.org/mesyto/vocab/sex/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

sex: a skos:ConceptScheme ;
    dct:title "Sex vocabulary"@en ;
    dct:creator "MeSyTo"@en ;
    dct:created "2026-05-15"^^xsd:date ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    skos:hasTopConcept sex:female, sex:male, sex:hermaphrodite, sex:unknown, sex:notApplicable .

sex:female a skos:Concept ;
    skos:prefLabel "female"@en ;
    skos:topConceptOf sex: .

sex:male a skos:Concept ;
    skos:prefLabel "male"@en ;
    skos:topConceptOf sex: .

sex:hermaphrodite a skos:Concept ;
    skos:prefLabel "hermaphrodite"@en ;
    skos:topConceptOf sex: .

sex:unknown a skos:Concept ;
    skos:prefLabel "unknown"@en ;
    skos:topConceptOf sex: .

sex:notApplicable a skos:Concept ;
    skos:prefLabel "not applicable"@en ;
    skos:topConceptOf sex: .
