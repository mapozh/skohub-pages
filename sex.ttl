@prefix mesyto: <https://w3id.org/mesyto/ontology#> .
@prefix mesyto-vocab: <https://w3id.org/mesyto/vocab/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

mesyto:sexConcept a rdfs:Class ;
    rdfs:label "sex concept" .

mesyto-vocab:sex a skos:ConceptScheme ;
    skos:prefLabel "sex" ;
    dcterms:creator "MeSyTo" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    skos:hasTopConcept mesyto:Female ,
                       mesyto:Male ,
                       mesyto:Hermaphrodite ,
                       mesyto:Unknown ,
                       mesyto:NotApplicable .

mesyto:Female a mesyto:sexConcept, skos:Concept ;
    rdfs:label "female" ;
    skos:prefLabel "female" ;
    skos:inScheme mesyto-vocab:sex ;
    skos:topConceptOf mesyto-vocab:sex .

mesyto:Male a mesyto:sexConcept, skos:Concept ;
    rdfs:label "male" ;
    skos:prefLabel "male" ;
    skos:inScheme mesyto-vocab:sex ;
    skos:topConceptOf mesyto-vocab:sex .

mesyto:Hermaphrodite a mesyto:sexConcept, skos:Concept ;
    rdfs:label "hermaphrodite" ;
    skos:prefLabel "hermaphrodite" ;
    skos:inScheme mesyto-vocab:sex ;
    skos:topConceptOf mesyto-vocab:sex .

mesyto:Unknown a mesyto:sexConcept, skos:Concept ;
    rdfs:label "unknown" ;
    skos:prefLabel "unknown" ;
    skos:inScheme mesyto-vocab:sex ;
    skos:topConceptOf mesyto-vocab:sex .

mesyto:NotApplicable a mesyto:sexConcept, skos:Concept ;
    rdfs:label "not applicable" ;
    skos:prefLabel "not applicable" ;
    skos:inScheme mesyto-vocab:sex ;
    skos:topConceptOf mesyto-vocab:sex .
