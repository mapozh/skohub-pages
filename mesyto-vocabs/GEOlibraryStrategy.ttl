@prefix mesyto: <https://w3id.org/mesyto/ontology#> .
@prefix mesyto-vocab: <https://w3id.org/mesyto/vocab/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

mesyto:GEOlibraryStrategyConcept a rdfs:Class ;
    rdfs:label "GEOlibraryStrategy concept" .

mesyto-vocab:GEOlibraryStrategy a skos:ConceptScheme ;
    skos:prefLabel "GEOlibraryStrategy" ;
    dcterms:creator "MeSyTo" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    skos:hasTopConcept mesyto:RNASeq ,
                       mesyto:ScRNASeq ,
                       mesyto:MiRNASeq ,
                       mesyto:NcRNASeq ,
                       mesyto:ChIPSeq ,
                       mesyto:ATACSeq ,
                       mesyto:BisulfiteSeq ,
                       mesyto:BisulfiteSeqReducedRepresentation ,
                       mesyto:SpatialTranscriptomics ,
                       mesyto:CITESeq ,
                       mesyto:CUTRun ,
                       mesyto:CUTTag ,
                       mesyto:MNaseSeq ,
                       mesyto:HiC ,
                       mesyto:MBDSeq ,
                       mesyto:MRESeq ,
                       mesyto:MeDIPSeq ,
                       mesyto:DNaseHypersensitivity ,
                       mesyto:TnSeq ,
                       mesyto:FAIRESeq ,
                       mesyto:SELEX ,
                       mesyto:RIPSeq ,
                       mesyto:ChIAPET ,
                       mesyto:BRUSeq ,
                       mesyto:CRISPRScreen ,
                       mesyto:CaptureC ,
                       mesyto:ChECSeq ,
                       mesyto:ChIRPSeq ,
                       mesyto:DamIDSeq ,
                       mesyto:EMSeq ,
                       mesyto:GROSeq ,
                       mesyto:HiChIP ,
                       mesyto:MeRIPSeq ,
                       mesyto:PROSeq ,
                       mesyto:RNAMethylation ,
                       mesyto:RiboSeq ,
                       mesyto:TCRSeq ,
                       mesyto:BCRSeq ,
                       mesyto:ICLIP ,
                       mesyto:SmallRNASeq ,
                       mesyto:SnRNASeq ,
                       mesyto:SsRNASeq ,
                       mesyto:RNASeqCAGE ,
                       mesyto:RNASeqRACE ,
                       mesyto:16SRRNASeq ,
                       mesyto:4CSeq ,
                       mesyto:OTHERSpecify .

mesyto:RNASeq a mesyto:GEOlibraryStrategyConcept, skos:Concept ;
    rdfs:label "RNA-Seq" ;
    skos:prefLabel "RNA-Seq" ;
    skos:inScheme mesyto-vocab:GEOlibraryStrategy ;
    skos:topConceptOf mesyto-vocab:GEOlibraryStrategy .

