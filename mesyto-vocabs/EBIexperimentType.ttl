@prefix mesyto: <https://w3id.org/mesyto/ontology#> .
@prefix mesyto-vocab: <https://w3id.org/mesyto/vocab/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

mesyto:EBIexperimentTypeConcept a rdfs:Class ;
    rdfs:label "EBI experimentType concept" .

mesyto-vocab:EBIexperimentType a skos:ConceptScheme ;
    skos:prefLabel "EBI experimentType" ;
    dcterms:creator "MeSyTo" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    skos:hasTopConcept mesyto:EBI4C ,
                       mesyto:EBIAntigenProfiling ,
                       mesyto:EBIATACSeq ,
                       mesyto:EBIBisulfiteSeq ,
                       mesyto:EBICaptureC ,
                       mesyto:EBIChIPChipByArray ,
                       mesyto:EBIChIPChipBySNPArray ,
                       mesyto:EBIChIPChipByTilingArray ,
                       mesyto:EBIChIPSeq ,
                       mesyto:EBICLIPSeq ,
                       mesyto:EBIComparativeGenomicHybridizationByArray ,
                       mesyto:EBICUTRUN ,
                       mesyto:EBIDNASeq ,
                       mesyto:EBIExomeSequencing ,
                       mesyto:EBIFAIRESeq ,
                       mesyto:EBIGenotypingByArray ,
                       mesyto:EBIGenotypingByHighThroughputSequencing ,
                       mesyto:EBIGROSeq ,
                       mesyto:EBIHiC ,
                       mesyto:EBIMeDIPSeq ,
                       mesyto:EBIMetabolomicProfiling ,
                       mesyto:EBIMethylationProfilingByArray ,
                       mesyto:EBIMethylationProfilingByHighThroughputSequencing ,
                       mesyto:EBIMicroRNAProfilingByArray ,
                       mesyto:EBIMicroRNAProfilingByHighThroughputSequencing ,
                       mesyto:EBIMNaseSeq ,
                       mesyto:EBIProteomicProfilingByArray ,
                       mesyto:EBIRIPChipByArray ,
                       mesyto:EBIRiboSeq ,
                       mesyto:EBIRIPSeq ,
                       mesyto:EBIRNASeqOfCodingRNA ,
                       mesyto:EBIRNASeqOfCodingRNAFromSingleCells ,
                       mesyto:EBIRNASeqOfNonCodingRNA ,
                       mesyto:EBIRNASeqOfNonCodingRNAFromSingleCells ,
                       mesyto:EBIRNASeqOfTotalRNA ,
                       mesyto:EBIScATACSeq ,
                       mesyto:EBISingleNucleusRNASequencing ,
                       mesyto:EBISpatialTranscriptomicsByHighThroughputSequencing ,
                       mesyto:EBITilingPathByArray ,
                       mesyto:EBITranscriptionProfilingByArray ,
                       mesyto:EBITranscriptionProfilingByMPSS ,
                       mesyto:EBITranscriptionProfilingByRTPCR ,
                       mesyto:EBITranscriptionProfilingBySAGE ,
                       mesyto:EBITranscriptionProfilingByTilingArray ,
                       mesyto:EBITranslationProfiling ,
                       mesyto:EBIWholeChromosomeRandomSequencing .

