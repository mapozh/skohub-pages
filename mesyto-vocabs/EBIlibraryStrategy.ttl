mesyto:EBIlibraryStrategyConcept a rdfs:Class ;
    rdfs:label "EBI libraryStrategy concept" .

mesyto-vocab:EBIlibraryStrategy a skos:ConceptScheme ;
    skos:prefLabel "EBI libraryStrategy" ;
    dcterms:creator "MeSyTo" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    skos:hasTopConcept mesyto:EBIWGSWholeGenomeSequencingRandomSequencingOfTheWholeGenomeSeePubmed10731132ForDetails ,
                       mesyto:EBIWGAWholeGenomeAmplificationFollowedByRandomSequencingSeePubmed16310678962113ForDetails ,
                       mesyto:EBIWXSRandomSequencingOfExonicRegionsSelectedFromTheGenomeSeePubmed20111037ForDetails ,
                       mesyto:EBIRNASeqRandomSequencingOfWholeTranscriptomeAlsoKnownAsWholeTranscriptomeShotgunSequencingOrWTSSSeePubmed18611170ForDetails ,
                       mesyto:EBISSRNASeqStrandSpecificRNASequencing ,
                       mesyto:EBIMiRNASeqMicroRNASequencingStrategyDesignedToCapturePostTranscriptionalRNAElementsAndIncludeNonCodingFunctionalElementsSeePubmed21787409ForDetails ,
                       mesyto:EBICRNASeqCaptureOfOtherNonCodingRNATypesIncludingPostTranslationModificationTypesSuchAsSRNASmallNuclearRNAOrSnORNASmallNucleolarRNAOrExpressionRegulationTypesSuchAsSiRNASmallInterferingRNAOrPiRNAPiwiRNAPiwiInteractingRNA ,
                       mesyto:EBIFLCDNAFullLengthSequencingOfDNATemplates ,
                       mesyto:EBIESTSinglePassSequencingOfDNATemplates ,
                       mesyto:EBIHiCChromosomeConformationCaptureTechniqueWhereABiotinLabeledNucleotideIsIncorporatedAtTheLigationJunctionEnablingSelectivePurificationOfChimericDNALigationJunctionsFollowedByDeepSequencing ,
                       mesyto:EBIATACSeqAssayForTransposaseAccessibleChromatinATACStrategyIsUsedToStudyGenomeWideChromatinAccessibilityAlternativeMethodToDNaseSeaThatUsesAnEngineeredTnTransposaseToCleaveDNAAndToIntegratePrimerDNASequencesIntoTheCleavedGenomicDNA ,
                       mesyto:EBIWCSRandomSequencingOfAWholeChromosomeOrOtherRepliconIsolatedFromAGenome ,
                       mesyto:EBIRADSeq ,
                       mesyto:EBICLONEGenomicCloneBasedHierarchicalSequencing ,
                       mesyto:EBIPOOLCLONEShotgunOfPooledClonesUsuallyBACsAndFosmids ,
                       mesyto:EBIAMPLICONSequencingOfOverlappingOrDistinctPCROrRTPCRProducts ,
                       mesyto:EBICLONEENDCloneEnd53OrBothSequencing ,
                       mesyto:EBIFINISHINGSequencingIntendedToFinishCloseGapsInExistingCoverage ,
                       mesyto:EBIChipSeqDirectSequencingOfChromatinImmunoprecipitates ,
                       mesyto:EBIMNaseSeqDirectSequencingFollowingMNaseDigestion ,
                       mesyto:EBIDNaseHypersensitivitySequencingOfHypersensitiveSitesOrSegmentsOfOpenChromatinThatAreMoreReadilyCleavedByDNasel ,
                       mesyto:EBIBisulfiteSeqSequencingFollowingTreatmentOfDNAWithBisulfiteToConvertCytosineResiduesToUracilDependingOnMethylationStatus ,
                       mesyto:EBICTSConcatenatedTagSequencing ,
                       mesyto:EBIMRESeqMethylationSensitiveRestrictionEnzymeSegencing ,
                       mesyto:EBIMeDIPSeqMethylatedDNAImmunoprecipitationSequencing ,
                       mesyto:EBIMBDSeqMethylCpGBindingDomainSequencing ,
                       mesyto:EBITnSeqQuantitativelyDetermineFitnessOfBacterialGenesBasedOnHowManyTimesAPurposelySeededTransposonGetsInsertedIntoEachGeneOfAColonyAfterSomeTime ,
                       mesyto:EBIVALIDATION ,
                       mesyto:EBIEARESeqFormaldehydeAssistedIsolationOfRegulatoryElementsRevealsRegionsOfOpenChromatin ,
                       mesyto:EBISELEXSystematicEvolutionOfLigandsByExponentialEnrichment ,
                       mesyto:EBIRiPSeqDirectSequencingOfRNAImmunoprecipitatesIncludesCLIPSeqHITSCLIPAndPARCLI .

mesyto:EBIWGSWholeGenomeSequencingRandomSequencingOfTheWholeGenomeSeePubmed10731132ForDetails a mesyto:EBIlibraryStrategyConcept, skos:Concept ;
    rdfs:label "WGS (Whole Genome Sequencing - random sequencing of the whole genome (see pubmed 10731132 for details))" ;
    skos:prefLabel "WGS (Whole Genome Sequencing - random sequencing of the whole genome (see pubmed 10731132 for details))" ;
    skos:inScheme mesyto-vocab:EBIlibraryStrategy ;
    skos:topConceptOf mesyto-vocab:EBIlibraryStrategy .

mesyto:EBIWGAWholeGenomeAmplificationFollowedByRandomSequencingSeePubmed16310678962113ForDetails a mesyto:EBIlibraryStrategyConcept, skos:Concept ;
    rdfs:label "WGA (Whole Genome Amplification followed by random sequencing. (see pubmed 1631067,8962113 for details))" ;
    skos:prefLabel "WGA (Whole Genome Amplification followed by random sequencing. (see pubmed 1631067,8962113 for details))" ;
    skos:inScheme mesyto-vocab:EBIlibraryStrategy ;
    skos:topConceptOf mesyto-vocab:EBIlibraryStrategy .

mesyto:EBIWXSRandomSequencingOfExonicRegionsSelectedFromTheGenomeSeePubmed20111037ForDetails a mesyto:EBIlibraryStrategyConcept, skos:Concept ;
    rdfs:label "WXS (Random sequencing of exonic regions selected from the genome. (see pubmed 20111037 for details))" ;
    skos:prefLabel "WXS (Random sequencing of exonic regions selected from the genome. (see pubmed 20111037 for details))" ;
    skos:inScheme mesyto-vocab:EBIlibraryStrategy ;
