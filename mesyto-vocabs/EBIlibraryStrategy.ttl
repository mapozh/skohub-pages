mesyto:EBIRNASeqRandomSequencingOfWholeTranscriptomeAlsoKnownAsWholeTranscriptomeShotgunSequencingOrWTSSSeePubmed18611170ForDetails a mesyto:EBIlibraryStrategyConcept, skos:Concept ;
    rdfs:label "RNA-Seq (Random sequencing of whole transcriptome, also known as Whole Transcriptome Shotgun Sequencing, or WTSS. (see pubmed 18611170 for details) )" ;
    skos:prefLabel "RNA-Seq (Random sequencing of whole transcriptome, also known as Whole Transcriptome Shotgun Sequencing, or WTSS. (see pubmed 18611170 for details) )" ;
