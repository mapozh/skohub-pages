    skos:topConceptOf mesyto-vocab:EBIlibraryStrategy .

mesyto:EBISSRNASeqStrandSpecificRNASequencing a mesyto:EBIlibraryStrategyConcept, skos:Concept ;
    rdfs:label "SSRNA-seq (Strand-specific RNA sequencing)" ;
