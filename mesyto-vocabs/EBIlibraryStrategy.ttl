mesyto:EBIMiRNASeqMicroRNASequencingStrategyDesignedToCapturePostTranscriptionalRNAElementsAndIncludeNonCodingFunctionalElementsSeePubmed21787409ForDetails a mesyto:EBIlibraryStrategyConcept, skos:Concept ;
    rdfs:label "miRNA-Seq (Micro RNA sequencing strategy designed to capture post-transcriptional RNA elements and include non-coding functional elements. (see pubmed 21787409 for details))" ;
    skos:prefLabel "miRNA-Seq (Micro RNA sequencing strategy designed to capture post-transcriptional RNA elements and include non-coding functional elements. (see pubmed 21787409 for details))" ;
    skos:inScheme mesyto-vocab:EBIlibraryStrategy ;
    skos:topConceptOf mesyto-vocab:EBIlibraryStrategy .

mesyto:EBICRNASeqCaptureOfOtherNonCodingRNATypesIncludingPostTranslationModificationTypesSuchAsSRNASmallNuclearRNAOrSnORNASmallNucleolarRNAOrExpressionRegulationTypesSuchAsSiRNASmallInterferingRNAOrPiRNAPiwiRNAPiwiInteractingRNA a mesyto:EBIlibraryStrategyConcept, skos:Concept ;
    rdfs:label "CRNA-Seq (Capture of other non-coding RNA types, including post-translation modification types such as sRNA (small nuclear RNA) or SnORNA (small nucleolar RNA), or expression regulation types such as siRNA (small interfering RNA) or piRNA/piwi/RNA (piwi-interacting RNA),)" ;
    skos:prefLabel "CRNA-Seq (Capture of other non-coding RNA types, including post-translation modification types such as sRNA (small nuclear RNA) or SnORNA (small nucleolar RNA), or expression regulation types such as siRNA (small interfering RNA) or piRNA/piwi/RNA (piwi-interacting RNA),)" ;
    skos:inScheme mesyto-vocab:EBIlibraryStrategy ;
    skos:topConceptOf mesyto-vocab:EBIlibraryStrategy .

mesyto:EBIFLCDNAFullLengthSequencingOfDNATemplates a mesyto:EBIlibraryStrategyConcept, skos:Concept ;
    rdfs:label "FL-CDNA (Full-length sequencing of DNA templates)" ;
    skos:prefLabel "FL-CDNA (Full-length sequencing of DNA templates)" ;
    skos:inScheme mesyto-vocab:EBIlibraryStrategy ;
    skos:topConceptOf mesyto-vocab:EBIlibraryStrategy .

mesyto:EBIESTSinglePassSequencingOfDNATemplates a mesyto:EBIlibraryStrategyConcept, skos:Concept ;
    rdfs:label "EST (Single pass sequencing of DNA templates)" ;
    skos:prefLabel "EST (Single pass sequencing of DNA templates)" ;
    skos:inScheme mesyto-vocab:EBIlibraryStrategy ;
    skos:topConceptOf mesyto-vocab:EBIlibraryStrategy .

mesyto:EBIHiCChromosomeConformationCaptureTechniqueWhereABiotinLabeledNucleotideIsIncorporatedAtTheLigationJunctionEnablingSelectivePurificationOfChimericDNALigationJunctionsFollowedByDeepSequencing a mesyto:EBIlibraryStrategyConcept, skos:Concept ;
    rdfs:label "Hi-C (Chromosome Conformation Capture technique where a biotin-labeled nucleotide is incorporated at the ligation junction, enabling selective purification of chimeric DNA ligation junctions followed by deep sequencing.)" ;
    skos:prefLabel "Hi-C (Chromosome Conformation Capture technique where a biotin-labeled nucleotide is incorporated at the ligation junction, enabling selective purification of chimeric DNA ligation junctions followed by deep sequencing.)" ;
    skos:inScheme mesyto-vocab:EBIlibraryStrategy ;
    skos:topConceptOf mesyto-vocab:EBIlibraryStrategy .

mesyto:EBIATACSeqAssayForTransposaseAccessibleChromatinATACStrategyIsUsedToStudyGenomeWideChromatinAccessibilityAlternativeMethodToDNaseSeaThatUsesAnEngineeredTnTransposaseToCleaveDNAAndToIntegratePrimerDNASequencesIntoTheCleavedGenomicDNA a mesyto:EBIlibraryStrategyConcept, skos:Concept ;
    rdfs:label "ATAC-seq (Assay for Transposase-Accessible Chromatin (ATAC) strategy is used to study genome-wide chromatin accessibility. alternative method to DNase-sea that uses an engineered Tn transposase to cleave DNA and to integrate primer DNA sequences into the cleaved genomic DNA.)" ;
    skos:prefLabel "ATAC-seq (Assay for Transposase-Accessible Chromatin (ATAC) strategy is used to study genome-wide chromatin accessibility. alternative method to DNase-sea that uses an engineered Tn transposase to cleave DNA and to integrate primer DNA sequences into the cleaved genomic DNA.)" ;
    skos:inScheme mesyto-vocab:EBIlibraryStrategy ;
    skos:topConceptOf mesyto-vocab:EBIlibraryStrategy .

