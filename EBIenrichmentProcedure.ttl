@prefix mesyto: <https://w3id.org/mesyto/ontology#> .
@prefix mesyto-vocab: <https://w3id.org/mesyto/vocab/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

mesyto:EBIenrichmentProcedureConcept a rdfs:Class ;
    rdfs:label "EBI enrichmentProcedure concept" .

mesyto-vocab:EBIenrichmentProcedure a skos:ConceptScheme ;
    skos:prefLabel "EBI enrichmentProcedure" ;
    dcterms:creator "MeSyTo" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    skos:hasTopConcept mesyto:EBIRANDOMRandomSelectionByShearingOrOtherMethod ,
                       mesyto:EBIPCRSourceMaterialWasSelectedByDesignedPrimers ,
                       mesyto:EBIRANDOMPCRSourceMaterialWasSelectedByRandomlyGeneratedPrimers ,
                       mesyto:EBIRTPCRSourceMaterialWasSelectedByReverseTranscriptionPCR ,
                       mesyto:EBIHMPRHypoMethylatedPartialRestrictionDigest ,
                       mesyto:EBIMFMethylFiltered ,
                       mesyto:EBIRepeatFractionationRepeatsCFSCFMCFHCFT ,
                       mesyto:EBISizeFractionation ,
                       mesyto:EBIMSLLMethylationSpanningLinkingLibrary ,
                       mesyto:EBICDNARandomPriming ,
                       mesyto:EBIPolyAPolyASelectionOrEnrichmentForMessengerRNAMRNA ,
                       mesyto:EBIOligoDTEnrichmentOfMessengerRNAMRNAByHybridizationToOligoDT ,
                       mesyto:EBIInverseRNADepletionOfRibosomalRNAByOligoHybridization ,
                       mesyto:EBIInverseRRNASelectionDepletionOfRibosomalRNAByInverseOligoHybridization ,
                       mesyto:EBIChIPChromatinImmunoprecipitation ,
                       mesyto:EBIMNaseMicrococcalNucleaseMNaseDigestion ,
                       mesyto:EBIDNaseDNaseIEndonucleaseDigestionAndSizeSelectionRevealsRegionsOfChromatinWhereTheDNAIsHighlySensitiveToDNaseI ,
                       mesyto:EBIHybridSelectionSelectionByHybridizationInArrayOrSolution ,
                       mesyto:EBIReducedRepresentationReproducibleGenomicSubsetsOftenGeneratedByRestrictionFragmentSizeSelectionContainingAManageableNumberOfLociToFacilitateReSampling ,
                       mesyto:EBIRestrictionDigestDNAFractionationUsingRestrictionEnzymes ,
                       mesyto:EBI5MethylcytidineAntibodySelectionOfMethylatedDNAFragmentsUsingAnAntibodyRaisedAgainst5MethylcytosineOr5MethylcytidineM5C ,
                       mesyto:EBIMBD2ProteinMethylCpGBindingDomainEnrichmentByMethylCpGBindingDomain ,
                       mesyto:EBICAGECapAnalysisGeneExpression ,
                       mesyto:EBIRACERapidAmplificationOfCDNAEnds ,
                       mesyto:EBIMDAMultipleDisplacementAmplification .

mesyto:EBIRANDOMRandomSelectionByShearingOrOtherMethod a mesyto:EBIenrichmentProcedureConcept, skos:Concept ;
