mesyto:GEOsequencingPlatformConcept a rdfs:Class ;
    rdfs:label "GEOsequencingPlatform concept" .

mesyto-vocab:GEOsequencingPlatform a skos:ConceptScheme ;
    skos:prefLabel "GEOsequencingPlatform" ;
